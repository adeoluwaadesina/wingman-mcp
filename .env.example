# Wingman Cloud configuration. Copy to .env and fill real values.
# NEVER commit real secrets. Placeholders only in this file.

# Neon Postgres connection string (pooled endpoint is fine; the app sets
# statement_cache_size=0 for PgBouncer compatibility).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/db?sslmode=require

# WorkOS AuthKit (OAuth 2.1 identity provider).
WORKOS_API_KEY=sk_example
WORKOS_CLIENT_ID=client_example
# AuthKit domain, NO trailing slash (must match the token's iss claim exactly).
WORKOS_ISSUER=https://your-tenant.authkit.app
# Optional: override the JWKS URL. If unset, it is auto-discovered from the
# issuer's /.well-known/openid-configuration (WorkOS AuthKit uses /oauth2/jwks).
WORKOS_JWKS_URI=

# Public HTTPS base URL of this service (used in OAuth metadata + token audience).
WINGMAN_BASE_URL=https://your-wingman.onrender.com

# Comma-separated CORS allow-list (never use "*"). Empty disables CORS.
ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com

# Optional observability. Unset = disabled.
SENTRY_DSN=
POSTHOG_KEY=

# Optional quota overrides (defaults shown).
MAX_PLANS_PER_USER=100
MAX_TASKS_PER_PLAN=500
MAX_BATCH_SIZE=50
MAX_BODY_BYTES=262144

# Port uvicorn binds (Render sets this automatically).
PORT=8000

# Operator metrics: set to enable GET /admin/stats (send as X-Admin-Token header).
# Unset = the endpoint is disabled (404).
ADMIN_TOKEN=
# Optional: override the userinfo endpoint (auto-discovered from the issuer otherwise).
WORKOS_USERINFO_URL=
